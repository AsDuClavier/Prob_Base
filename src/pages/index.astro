---
// Page d'accueil avec accès administration sécurisé par code secret
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Répertoire de problèmes</title>
  <style>
    html { 
      scrollbar-gutter: stable; 
    }
    *, *::before, *::after { 
      box-sizing: border-box; 
    }
    body {
      font-family: 'Segoe UI', system-ui, sans-serif;
      background-color: #f0f4f8;
      color: #2d3748;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }
    .container {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      max-width: 800px;
      margin: 0 auto;
      padding: 40px 20px;
      width: 100%;
    }
    h1 {
      background: linear-gradient(135deg, #1e3c72, #3498db);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      font-size: 2.8rem;
      text-align: center;
      margin-bottom: 15px;
      font-weight: 800;
      letter-spacing: -0.5px;
    }
    .description {
      font-size: 1.15rem;
      color: #4a5568;
      text-align: center;
      max-width: 600px;
      line-height: 1.6;
      margin-top: 0;
      margin-bottom: 45px;
    }
    .portal-grid {
      display: flex;
      gap: 25px;
      width: 100%;
      max-width: 650px;
      flex-direction: column;
    }
    @media (min-width: 600px) {
      .portal-grid {
        flex-direction: row;
      }
    }
    .portal-btn {
      flex: 1;
      display: flex;
      justify-content: center;
      align-items: center;
      text-align: center;
      text-decoration: none;
      padding: 35px 25px;
      font-size: 1.3rem;
      font-weight: 700;
      border-radius: 12px;
      min-height: 150px;
      transition: transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.25s ease;
    }
    
    .portal-btn.active {
      background: linear-gradient(135deg, #3498db, #5f27cd);
      color: white;
      box-shadow: 0 10px 20px rgba(95, 39, 205, 0.2);
    }
    .portal-btn.active:hover {
      transform: translateY(-6px);
      box-shadow: 0 15px 28px rgba(95, 39, 205, 0.35);
    }
    
    .portal-btn.disabled {
      background: #e2e8f0;
      color: #a0aec0;
      border: 2px dashed #cbd5e0;
      cursor: not-allowed;
    }
    .portal-btn.disabled:hover {
      transform: none;
    }

    /* Styles du Footer et du système de déverrouillage */
    footer {
      padding: 30px 20px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 15px;
      width: 100%;
    }
    .secret-input {
      padding: 6px 12px;
      border: 1px solid #cbd5e0;
      border-radius: 6px;
      font-size: 12px;
      outline: none;
      text-align: center;
      width: 120px;
      background: transparent;
      color: #718096;
      transition: all 0.2s ease;
    }
    .secret-input:focus {
      border-color: #a0aec0;
      width: 140px;
    }
    .admin-links-container {
      display: none; /* Masqué par défaut */
      gap: 20px;
      flex-wrap: wrap;
      justify-content: center;
    }
    .admin-links-container.visible {
      display: flex; /* Affiché uniquement lorsque la classe est ajoutée */
    }
    .admin-link {
      font-size: 13px;
      color: #a0aec0;
      text-decoration: none;
      transition: color 0.2s, transform 0.2s;
      font-weight: 600;
      display: inline-block;
    }
    .admin-link:hover {
      color: #4a5568;
      transform: scale(1.02);
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>Répertoire de problèmes</h1>
    
    <p class="description">
      Bienvenue sur votre plateforme dédiée à l'entraînement et à la résolution de problèmes mathématiques rigoureux. Sélectionnez une section ci-dessous pour accéder aux énoncés, indices et solutions rédigées.
    </p>
    
    <div class="portal-grid">
      <a href="/Prob_Base/general" class="portal-btn active">
        Problèmes généraux
      </a>
      
      <a href="/Prob_Base/fhb" class="portal-btn active">
        Problème type Concours FHB
      </a>
    </div>
  </div>

  <footer>
    <!-- Petit champ discret simulé en type password pour masquer la saisie -->
    <input type="password" id="secretGate" class="secret-input" placeholder="Clé d'accès..." />

    <!-- Conteneur d'administration masqué -->
    <div id="adminContainer" class="admin-links-container">
      <p>Problèmes généraux</p>
      <a href="/Prob_Base/admin-add" class="admin-link">⚙️ Ajout -Problèmes généraux</a>
      <a href="/Prob_Base/admin" class="admin-link">⚙️ Edit -Problèmes généraux</a>
    </div>
    
    <div id="adminContainer" class="admin-links-container">
      <p>Problèmes FHB</p>
      <a href="/Prob_Base/adminfhb-add" class="admin-link">⚙️ Ajout -Problèmes FHB</a>
      <a href="/Prob_Base/adminfhb-edit" class="admin-link">⚙️ Edit -Problèmes FHB</a>
    </div>
  </footer>

  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      const secretGate = document.getElementById('secretGate');
      const adminContainer = document.getElementById('adminContainer');
      
      // CONFIGURATION : Changez "admin" par le mot secret de votre choix
      const SECRET_KEY = "admin"; 

      secretGate.addEventListener('input', () => {
        if (secretGate.value.trim() === SECRET_KEY) {
          adminContainer.classList.add('visible'); // Affiche les liens
          secretGate.style.display = 'none';      // Masque définitivement le champ de saisie
        }
      });
    });
  </script>
</body>
</html>
