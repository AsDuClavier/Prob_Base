---
// @ts-nocheck
import problems from '../data/problems.json';
import theorems from '../data/theorems.json';
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Répertoire de problèmes & Théorèmes</title>
  
  <!-- Chargement de KaTeX pour les cartes aléatoires -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/contrib/auto-render.min.js"></script>

  <style>
    html { scrollbar-gutter: stable; }
    *, *::before, *::after { box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', system-ui, sans-serif;
      background-color: #f0f4f8;
      color: #2d3748;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }
    .container {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      max-width: 900px;
      margin: 0 auto;
      padding: 40px 20px;
      width: 100%;
    }
    h1 {
      background: linear-gradient(135deg, #1e3c72, #2ecc71);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      font-size: 2.8rem;
      text-align: center;
      margin-bottom: 15px;
      font-weight: 800;
      letter-spacing: -0.5px;
    }
    .description {
      font-size: 1.15rem;
      color: #4a5568;
      text-align: center;
      max-width: 600px;
      line-height: 1.6;
      margin-top: 0;
      margin-bottom: 40px;
    }
    .portal-grid {
      display: flex;
      gap: 20px;
      width: 100%;
      max-width: 800px;
      flex-direction: column;
      margin-bottom: 45px;
    }
    @media (min-width: 600px) {
      .portal-grid { flex-direction: row; }
    }
    .portal-btn {
      flex: 1;
      display: flex;
      justify-content: center;
      align-items: center;
      text-align: center;
      text-decoration: none;
      padding: 30px 20px;
      font-size: 1.25rem;
      font-weight: 700;
      border-radius: 12px;
      min-height: 120px;
      transition: transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.25s ease;
      color: white;
    }
    
    .portal-btn.prob-gen {
      background: linear-gradient(135deg, #3498db, #2980b9);
      box-shadow: 0 8px 16px rgba(52, 152, 219, 0.2);
    }
    .portal-btn.prob-fhb {
      background: linear-gradient(135deg, #e67e22, #d35400);
      box-shadow: 0 8px 16px rgba(230, 126, 34, 0.2);
    }
    .portal-btn.theorems {
      background: linear-gradient(135deg, #2ecc71, #27ae60);
      box-shadow: 0 8px 16px rgba(46, 204, 113, 0.2);
    }
    .portal-btn:hover {
      transform: translateY(-5px);
      box-shadow: 0 12px 24px rgba(0, 0, 0, 0.15);
    }

    /* Section Aléatoire */
    .random-section {
      width: 100%;
      max-width: 800px;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }
    @media (min-width: 768px) {
      .random-section { flex-direction: row; }
    }
    .random-card {
      flex: 1;
      background: white;
      padding: 20px;
      border-radius: 10px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.04);
      cursor: pointer;
      transition: transform 0.2s, box-shadow 0.2s;
      border-top: 4px solid #ccc;
    }
    .random-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 6px 15px rgba(0,0,0,0.08);
    }
    .random-card.prob { border-top-color: #3498db; }
    .random-card.theo { border-top-color: #2ecc71; }
    
    .random-card h3 {
      margin-top: 0;
      margin-bottom: 10px;
      font-size: 14px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: #718096;
    }
    .random-title {
      font-size: 16px;
      font-weight: 700;
      color: #2d3748;
      margin-bottom: 8px;
    }
    .random-snippet {
      font-size: 14px;
      color: #4a5568;
      line-height: 1.5;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    /* Footer & Admin */
    footer { padding: 30px 20px; display: flex; flex-direction: column; align-items: center; gap: 15px; width: 100%; }
    .secret-input { padding: 6px 12px; border: 1px solid #cbd5e0; border-radius: 6px; font-size: 12px; outline: none; text-align: center; width: 120px; background: transparent; color: #718096; transition: all 0.2s ease; }
    .secret-input:focus { border-color: #a0aec0; width: 140px; }
    .admin-links-container { display: none; gap: 15px; flex-wrap: wrap; justify-content: center; max-width: 700px; }
    .admin-links-container.visible { display: flex; }
    .admin-link { font-size: 13px; color: #a0aec0; text-decoration: none; transition: color 0.2s; font-weight: 600; }
    .admin-link:hover { color: #4a5568; }
  </style>
</head>
<body>
  <div class="container">
    <h1>Répertoire de problèmes</h1>
    
    <p class="description">
      Plateforme dédiée à l'entraînement et à la résolution de structures mathématiques rigoureuses. Sélectionnez une section ou explorez les découvertes aléatoires.
    </p>
    
    <div class="portal-grid">
      <a href="/Prob_Base/general" class="portal-btn prob-gen">Problèmes généraux</a>
      <a href="/Prob_Base/fhb" class="portal-btn prob-fhb">Concours FHB</a>
      <a href="/Prob_Base/theorems" class="portal-btn theorems">Théorèmes</a>
    </div>

    <div class="random-section">
      <div class="random-card prob" id="randProbCard">
        <h3>Problème Aléatoire 🎲</h3>
        <div class="random-title" id="randProbTitle">Chargement...</div>
        <div class="random-snippet math-target" id="randProbSnippet"></div>
      </div>

      <div class="random-card theo" id="randTheoCard">
        <h3>Théorème Aléatoire 💡</h3>
        <div class="random-title" id="randTheoTitle">Chargement...</div>
        <div class="random-snippet math-target" id="randTheoSnippet"></div>
      </div>
    </div>
  </div>

  <footer>
    <input type="password" id="secretGate" class="secret-input" placeholder="Clé d'accès..." />
    <div id="adminContainer" class="admin-links-container">
      <a href="/Prob_Base/admin-add" class="admin-link">⚙️+ Problèmes Généraux</a>
      <a href="/Prob_Base/admin" class="admin-link">⚙️✏️ Problèmes Généraux</a>
      <a href="/Prob_Base/adminfhb-add" class="admin-link">⚙️+ Problèmes FHB</a>
      <a href="/Prob_Base/adminfhb-edit" class="admin-link">⚙️✏️ Problèmes FHB</a>
      <a href="/Prob_Base/admin-theorems-add" class="admin-link">⚙️+ Théorèmes</a>
    </div>
  </footer>

  <!-- Injection sécurisée des listes JSON dans le script client -->
  <script is:inline define:vars={{ problems, theorems }}>
    window.addEventListener('DOMContentLoaded', () => {
      // 1. Gestion Authentification Secrète
      const secretGate = document.getElementById('secretGate');
      const adminContainer = document.getElementById('adminContainer');
      const SECRET_KEY = "admin"; 

      secretGate.addEventListener('input', () => {
        if (secretGate.value.trim() === SECRET_KEY) {
          adminContainer.classList.add('visible');
          secretGate.style.display = 'none';
        }
      });

      // 2. Sélection Aléatoire Problème
      if (problems && problems.length > 0) {
        const randProb = problems[Math.floor(Math.random() * problems.length)];
        document.getElementById('randProbTitle').innerText = randProb.Source ? `Source : ${randProb.Source}` : `Problème n°${randProb.id}`;
        document.getElementById('randProbSnippet').innerText = randProb.statement || "";
        document.getElementById('randProbCard').addEventListener('click', () => {
          window.location.href = `/Prob_Base/problems/${randProb.id}`;
        });
      }

      // 3. Sélection Aléatoire Théorème
      if (theorems && theorems.length > 0) {
        const randTheo = theorems[Math.floor(Math.random() * theorems.length)];
        document.getElementById('randTheoTitle').innerText = randTheo.title || `Théorème n°${randTheo.id}`;
        document.getElementById('randTheoSnippet').innerText = randTheo.statement || "";
        document.getElementById('randTheoCard').addEventListener('click', () => {
          window.location.href = `/Prob_Base/theo/${randTheo.id}`;
        });
      }

      // 4. Rendu Mathématique KaTeX
      if (typeof renderMathInElement === 'function') {
        renderMathInElement(document.body, {
          delimiters: [
            {left: '$$', right: '$$', display: true},
            {left: '$', right: '$', display: false}
          ],
          throwOnError: false
        });
      }
    });
  </script>
</body>
</html>
